<UserControl x:Class="MusicManager.Views.DownloadTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MusicManager.ViewModels"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">

    <UserControl.DataContext>
        <vm:DownloadViewModel />
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Input Row -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="UrlTextBox"
                     Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"
                     Height="34"
                     VerticalContentAlignment="Center"
                     Margin="0,0,8,0">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Resources>
                            <VisualBrush x:Key="HintBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                <VisualBrush.Visual>
                                    <TextBlock Text="Inserisci URL Spotify o nome artista..."
                                               Foreground="{StaticResource ForegroundMutedBrush}"
                                               Margin="6,0,0,0" />
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Style.Resources>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Button Grid.Column="1"
                    Content="🔍  Cerca"
                    Command="{Binding SearchCommand}"
                    Height="34"
                    Margin="0,0,8,0"
                    Style="{StaticResource GhostButtonStyle}" />

            <Button Grid.Column="2"
                    Content="➕  Aggiungi"
                    Command="{Binding AddCommand}"
                    Height="34" />
        </Grid>

        <!-- Action Buttons Row -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,12"
                    HorizontalAlignment="Left">
            <Button Content="▶  Avvia Coda"
                    Command="{Binding StartQueueCommand}"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding CanStartQueue}" />
            <Button Content="⏸  Pausa"
                    Command="{Binding PauseCommand}"
                    Margin="0,0,8,0"
                    Style="{StaticResource GhostButtonStyle}"
                    IsEnabled="{Binding IsQueueRunning}" />
            <Button Content="🔄  Sincronizza Tutto"
                    Command="{Binding SyncAllCommand}"
                    Style="{StaticResource GhostButtonStyle}" />
        </StackPanel>

        <!-- Queue ListView -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <ListView ItemsSource="{Binding QueueItems}"
                      BorderThickness="0"
                      Background="{StaticResource SurfaceBrush}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.View>
                    <GridView>

                        <!-- Status Icon -->
                        <GridViewColumn Header="  " Width="36">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusIcon}"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding Status}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Name / Type -->
                        <GridViewColumn Header="Nome" Width="280">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="0,2">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Type}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource ForegroundMutedBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Progress -->
                        <GridViewColumn Header="Progresso" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="0,2">
                                        <ProgressBar Value="{Binding Progress}"
                                                     Maximum="100"
                                                     Height="8"
                                                     Margin="0,0,0,2">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource ForegroundMutedBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="downloading">
                                                            <Setter Property="Text" Value="{Binding Progress, StringFormat={}{0}%}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="queued">
                                                            <Setter Property="Text" Value="In coda" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="done">
                                                            <Setter Property="Text" Value="Completato" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="error">
                                                            <Setter Property="Text" Value="Errore" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Date Added -->
                        <GridViewColumn Header="Aggiunto" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DateAdded, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                               FontSize="11"
                                               Foreground="{StaticResource ForegroundMutedBrush}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Action -->
                        <GridViewColumn Header="Azione" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="↩  Riprova"
                                            Command="{Binding DataContext.RetryCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            FontSize="11"
                                            Padding="6,3">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="error">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
